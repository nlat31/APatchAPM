<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="?attr/colorSurface">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/hide_dev_tip"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="12dp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardUseCompatPadding="true"
        app:cardElevation="1dp"
        app:strokeWidth="1dp"
        app:strokeColor="?attr/colorOutline">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchEnableHideDev"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/hide_dev_enable"
                android:textColor="?attr/colorOnSurface" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchHideDeveloperMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/hide_developer_mode"
                android:textColor="?attr/colorOnSurface" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchHideUsbDebug"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/hide_usb_debug"
                android:textColor="?attr/colorOnSurface" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchHideWirelessDebug"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/hide_wireless_debug"
                android:textColor="?attr/colorOnSurface" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchHideDebugProperties"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/hide_debug_properties"
                android:textColor="?attr/colorOnSurface" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchHideDebugPropertiesInNative"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/hide_debug_properties_in_native"
                android:textColor="?attr/colorOnSurface" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>

