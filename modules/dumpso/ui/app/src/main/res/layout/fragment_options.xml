<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkEnableHook"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/enable_dump_hook" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dump_mode"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:layout_marginTop="12dp" />

        <RadioGroup
            android:id="@+id/radioDumpMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/radioModeHook"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/dump_mode_hook" />

            <RadioButton
                android:id="@+id/radioModeEnumerate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/dump_mode_enumerate" />
        </RadioGroup>

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkWatch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/watch_loaded_libraries" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkOnLoad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/on_load" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkFix"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/rebuild_fix_so" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/delay_seconds"
            android:layout_marginTop="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editDelaySeconds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/enum_delay_seconds"
            android:layout_marginTop="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editEnumDelaySeconds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/so_name"
            android:layout_marginTop="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editSoName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/regex"
            android:layout_marginTop="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editRegex"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/regex_note"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>

